# Copy this file to `.env` and fill in the values. `.env` is gitignored.

# --- Database (PostgreSQL) -------------------------------------------------
# A Postgres connection string (Neon, Supabase, Vercel Postgres, etc.).
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# --- Auth.js v5 ------------------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""
AUTH_TRUST_HOST=true

# First admin user, created by `npm run db:seed`.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"
ADMIN_NAME="Site Admin"

# --- Cloudinary (image uploads) --------------------------------------------
# From your Cloudinary dashboard → Settings → API Keys.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# --- Contact form email delivery (optional) --------------------------------
# Without these, contact messages are still saved to the database.
RESEND_API_KEY=
CONTACT_TO_EMAIL="you@example.com"
CONTACT_FROM_EMAIL="Portfolio <onboarding@resend.dev>"
