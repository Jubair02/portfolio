# Contact form email delivery (optional).
# Create a free account at https://resend.com, add an API key, then copy this
# file to `.env.local` and fill in the values. Without these, the contact form
# still works but messages are only logged to the server console.

RESEND_API_KEY=
# Where contact-form messages are delivered (defaults to your portfolio email):
CONTACT_TO_EMAIL=jubu01754@gmail.com
# A verified Resend sender address (falls back to Resend's onboarding sender):
CONTACT_FROM_EMAIL="Portfolio <onboarding@resend.dev>"
